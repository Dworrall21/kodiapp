<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon
  id="repository.helix"
  name="Helix Repository"
  version="0.0.1"
  provider-name="Helix">
  <requires>
    <import addon="xbmc.addon" version="12.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="Helix Repository">
    <info>https://raw.githubusercontent.com/Dworrall21/kodiapp/gh-pages/addons.xml</info>
    <checksum>https://raw.githubusercontent.com/Dworrall21/kodiapp/gh-pages/addons.xml.md5</checksum>
    <datadir>https://raw.githubusercontent.com/Dworrall21/kodiapp/gh-pages</datadir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Helix add-on repository</summary>
    <description lang="en_GB">Holds the Helix add-on and any future Helix-family add-ons.</description>
    <disclaimer lang="en_GB">Content-neutral. The repository does not host any third-party media.</disclaimer>
    <language>en</language>
    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>icons/repo.png</icon>
    </assets>
  </extension>
</addon>
