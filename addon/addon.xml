<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.xbox.proxy" name="Xbox Web Proxy" version="1.0.5" provider-name="OWL">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="default.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary>Web Interface Proxy for Xbox</summary>
        <description>
            Proxies Kodi's web interface through an outbound WebSocket connection.
            This bypasses UWP inbound port restrictions on Xbox Retail Mode.
        </description>
        <platform>all</platform>
    </extension>
</addon>