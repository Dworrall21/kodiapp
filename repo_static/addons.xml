<?xml version='1.0' encoding='UTF-8'?>
<addons>
  <addon id="plugin.video.helix" name="Helix" version="0.4.0" provider-name="Helix">
    <requires>
      <import addon="xbmc.python" version="3.0.1" />
      <import addon="script.module.requests" version="2.27.0" optional="true" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py" />
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Browse debrid + M3U with TMDB metadata, toolkit, and dashboard</summary>
      <description lang="en_GB">Helix fuses TMDB-driven browsing with a full toolkit. Debrid-primary with Torrentio/Comet/BitMagnet indexers. M3U fallback. Trakt OAuth. Dashboard.</description>
      <disclaimer lang="en_GB">Content-neutral. No hosting/scraping of third-party media.</disclaimer>
      <language>en</language>
      <platform>all</platform>
      <license>MIT</license>
      <assets>
        <icon>resources/media/icon.png</icon>
        <fanart>resources/media/fanart.jpg</fanart>
        <screenshot>resources/media/screenshot-01.jpg</screenshot>
      </assets>
      <news>0.4.0 - New: Trending/Popular/Genres top-level, search with debrid cache badges, Trakt trending integration. 0.3.0 - Torrentio/Comet/BitMagnet indexers, debrid cache check, EPG. 0.2.0 - Dashboard. 0.1.0 - Initial.</news>
    </extension>
  </addon>
  <addon id="repository.helix" name="Helix Repository" version="0.0.1" provider-name="Helix">
    <requires>
      <import addon="xbmc.addon" version="12.0.0" />
    </requires>
    <extension point="xbmc.addon.repository" name="Helix Repository" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Helix add-on repository</summary>
      <description lang="en_GB">Holds the Helix add-on and supporting tools.</description>
      <language>en</language>
      <platform>all</platform>
      <license>MIT</license>
    </extension>
  </addon>

  <addon id="script.xbox.contentgate" name="Xbox Content Gate" version="1.0.0" provider-name="OWL">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.service" library="default.py" start="startup" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Content rating gate with dual-PIN access control</summary>
      <description lang="en_GB">Prompts for a passcode when playing content above a configurable rating threshold.</description>
      <language>en</language>
      <platform>all</platform>
      <license>MIT</license>
      <assets>
        <icon>resources/icon.png</icon>
      </assets>
    </extension>
  </addon>

<?xml version="1.0" encoding="UTF-8"?>
<addon id="script.xbox.proxy" name="Xbox Web Proxy" version="1.0.19" provider-name="OWL">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="default.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Web Interface Proxy for Xbox</summary>
        <description lang="en_GB">Proxies Kodi's web interface and selected management commands through an authenticated outbound WebSocket connection with diagnostics and binary-safe response handling.</description>
        <platform>all</platform>
        <license>MIT</license>
        <website>https://github.com/Dworrall21/kodiapp</website>
        <source>https://github.com/Dworrall21/kodiapp</source>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>

