<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="repository.dworrall21" name="Dworrall21 Kodi Repository" version="1.0.0" provider-name="Dworrall21">
        <extension point="xbmc.addon.repository" name="Dworrall21 Kodi Repository">
            <dir>
                <info compressed="false">https://dworrall21.github.io/kodiapp/addons.xml</info>
                <checksum>https://dworrall21.github.io/kodiapp/addons.xml.md5</checksum>
                <datadir zip="true">https://dworrall21.github.io/kodiapp/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Dworrall21 Kodi Repository</summary>
            <description lang="en_GB">Repository containing Dworrall21's Kodi add-ons including the Xbox Proxy.</description>
            <platform>all</platform>
            <license>MIT</license>
            <website>https://dworrall21.github.io/kodiapp/</website>
            <source>https://github.com/Dworrall21/kodiapp</source>
        </extension>
    </addon>
    <addon id="script.xbox.proxy" name="Xbox Web Proxy" version="1.0.6" provider-name="Dworrall21">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.service" library="default.py" start="startup"/>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Web Interface Proxy for Xbox</summary>
            <description lang="en_GB">Authenticated outbound WebSocket proxy for Kodi Xbox with diagnostics and binary-safe HTTP responses.</description>
            <platform>all</platform>
            <license>MIT</license>
            <website>https://github.com/Dworrall21/kodiapp</website>
            <source>https://github.com/Dworrall21/kodiapp</source>
        </extension>
    </addon>
</addons>
